{
  "consumer": {
    "name": "frontend-react"
  },
  "interactions": [
    {
      "description": "uma requisição para buscar produto por id",
      "providerStates": [
        {
          "name": "produto com id 1 existe"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products/1"
      },
      "response": {
        "body": {
          "category": "men's clothing",
          "description": "Your perfect pack for everyday use",
          "image": "https://fakestoreapi.com/img/81fAn.jpg",
          "price": 109.95,
          "rating": {
            "count": 120,
            "rate": 3.9
          },
          "title": "Fjallraven - Foldsack No. 1 Backpack"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.category": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.image": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "https?://.+"
                }
              ]
            },
            "$.price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.rating.count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.rating.rate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "uma requisição para listar todos os produtos",
      "providerStates": [
        {
          "name": "existem produtos cadastrados"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products"
      },
      "response": {
        "body": [
          {
            "category": "men's clothing",
            "description": "Your perfect pack for everyday use",
            "image": "https://fakestoreapi.com/img/81fAn.jpg",
            "price": 109.95,
            "rating": {
              "count": 120,
              "rate": 3.9
            },
            "title": "Fjallraven - Foldsack No. 1 Backpack"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].category": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].image": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "https?://.+"
                }
              ]
            },
            "$[*].price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].rating.count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].rating.rate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "uma requisição para produto inexistente",
      "providerStates": [
        {
          "name": "produto com id 999 não existe"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products/999"
      },
      "response": {
        "body": {
          "erro": "Produto não encontrado"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.erro": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 404
      }
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "api-produtos"
  }
}